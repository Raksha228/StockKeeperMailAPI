<UserControl x:Class="StockKeeperMail.Desktop.Controls.InvoiceDocumentControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             Width="900"
             MinHeight="1280"
             Background="{DynamicResource InvoiceBackgroundBrush}">

    <Grid Margin="32,48,32,52" TextOptions.TextFormattingMode="Display">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="18"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="18"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="18"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Верхний блок: банковские реквизиты -->
        <Border Grid.Row="0"
                BorderBrush="{DynamicResource InvoiceBorderBrush}"
                BorderThickness="1"
                Padding="0"
                Background="{DynamicResource InvoiceBackgroundBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="32"/>
                    <RowDefinition Height="32"/>
                    <RowDefinition Height="32"/>
                    <RowDefinition Height="32"/>
                    <RowDefinition Height="32"/>

                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="220"/>
                </Grid.ColumnDefinitions>

                <!-- row 0 -->
                <Border Grid.Row="0" Grid.Column="0" BorderBrush="{DynamicResource InvoiceBorderBrush}" BorderThickness="0,0,1,1" Padding="6">
                    <TextBlock Text="ИНН" VerticalAlignment="Center" FontSize="13"/>
                </Border>
                <Border Grid.Row="0" Grid.Column="1" BorderBrush="{DynamicResource InvoiceBorderBrush}" BorderThickness="0,0,1,1" Padding="6">
                    <TextBlock Text="614303992509" VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold"/>
                </Border>
                <Border Grid.Row="0" Grid.Column="2" BorderBrush="{DynamicResource InvoiceBorderBrush}" BorderThickness="0,0,1,1" Padding="6">
                    <TextBlock Text="Сч. №" VerticalAlignment="Center" FontSize="13"/>
                </Border>
                <Border Grid.Row="0" Grid.Column="3" BorderBrush="{DynamicResource InvoiceBorderBrush}" BorderThickness="0,0,0,1" Padding="6">
                    <TextBlock Text="40802810601100001593" VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold"/>
                </Border>

                <!-- row 1 -->
                <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" BorderBrush="{DynamicResource InvoiceBorderBrush}" BorderThickness="0,0,1,1" Padding="6">
                    <TextBlock Text="Получатель" VerticalAlignment="Center" FontSize="13"/>
                </Border>
                <Border Grid.Row="1" Grid.Column="2" BorderBrush="{DynamicResource InvoiceBorderBrush}" BorderThickness="0,0,1,1" Padding="6">
                    <TextBlock Text="БИК" VerticalAlignment="Center" FontSize="13"/>
                </Border>
                <Border Grid.Row="1" Grid.Column="3" BorderBrush="{DynamicResource InvoiceBorderBrush}" BorderThickness="0,0,0,1" Padding="6">
                    <TextBlock Text="046015762" VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold"/>
                </Border>

                <!-- row 2 -->
                <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" BorderBrush="{DynamicResource InvoiceBorderBrush}" BorderThickness="0,0,1,1" Padding="6">
                    <TextBlock Text="ИП Бахолдина Ольга Никитовна «ВолгоМед»"
                               VerticalAlignment="Center"
                               FontSize="13"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"/>
                </Border>
                <Border Grid.Row="2" Grid.Column="2" BorderBrush="{DynamicResource InvoiceBorderBrush}" BorderThickness="0,0,1,1" Padding="6">
                    <TextBlock Text="Сч. №" VerticalAlignment="Center" FontSize="13"/>
                </Border>
                <Border Grid.Row="2" Grid.Column="3" BorderBrush="{DynamicResource InvoiceBorderBrush}" BorderThickness="0,0,0,1" Padding="6">
                    <TextBlock Text="30101810100000000762" VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold"/>
                </Border>

                <!-- row 3 -->
                <Border Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" BorderBrush="{DynamicResource InvoiceBorderBrush}" BorderThickness="0,0,1,1" Padding="6">
                    <TextBlock Text="Банк получателя" VerticalAlignment="Center" FontSize="13"/>

                </Border>
                <Border Grid.Row="3" Grid.Column="2" Grid.ColumnSpan="2" BorderBrush="{DynamicResource InvoiceBorderBrush}" BorderThickness="0,0,0,1" Padding="6">
                    <TextBlock Text="" VerticalAlignment="Center" FontSize="13"/>
                </Border>

                <!-- row 4 -->
                <Border Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" BorderBrush="{DynamicResource InvoiceBorderBrush}" BorderThickness="0,0,1,1" Padding="6">
                    <TextBlock Text="ПАО КБ &quot;ЦЕНТР-ИНВЕСТ&quot;"
                               VerticalAlignment="Center"
                               FontSize="13"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"/>
                </Border>
                <Border Grid.Row="4" Grid.Column="2" Grid.ColumnSpan="2" BorderBrush="{DynamicResource InvoiceBorderBrush}" BorderThickness="0,0,0,1" Padding="6">
                    <TextBlock Text="" VerticalAlignment="Center" FontSize="13"/>
                </Border>

            </Grid>
        </Border>




        <!-- Заголовок -->
        <TextBlock Grid.Row="2"
                   Text="Счёт на оплату"
                   FontSize="24"
                   FontWeight="Bold"
                   Foreground="{DynamicResource InvoiceForegroundBrush}"
                   HorizontalAlignment="Center"/>

        <!-- Блок реквизитов и информации -->
        <StackPanel Grid.Row="4">
            <TextBlock Margin="0,0,0,6" FontSize="14" TextWrapping="Wrap">
                <Run Text="Поставщик: " FontWeight="Bold"/>
                <Run Text="ИП Бахолдина Ольга Никитовна «ВолгоМед», Волгодонск, Бульвар Великой Победы д. 11, помещение 10, ИНН 614303992509, ОГРН 324619600125852, р/с 40802810601100001593, ПАО КБ &quot;ЦЕНТР-ИНВЕСТ&quot;, к/с 30101810100000000762, БИК 046015762"/>
            </TextBlock>

            <TextBlock Margin="0,0,0,6" FontSize="14">
                <Run Text="Номер заказа: " FontWeight="Bold"/>
                <Run Text="{Binding Order.OrderID, Mode=OneWay}"/>
            </TextBlock>

            <TextBlock Margin="0,0,0,6" FontSize="14">
                <Run Text="Дата счёта: " FontWeight="Bold"/>
                <Run Text="{Binding CurrentDateTime,Mode=OneWay, StringFormat={}{0:dd.MM.yyyy}}"/>
            </TextBlock>

            <TextBlock Margin="0,0,0,6" FontSize="14">
                <Run Text="Дата заказа: " FontWeight="Bold"/>
                <Run Text="{Binding Order.OrderDate, Mode=OneWay}"/>
            </TextBlock>

            <TextBlock Margin="0,0,0,6" FontSize="14">
                <Run Text="Email: " FontWeight="Bold"/>
                <Run Text="volgomedmail@mail.ru"/>
            </TextBlock>

            <TextBlock Margin="0,0,0,6" FontSize="14">
                <Run Text="Контактный телефон: " FontWeight="Bold"/>
                <Run Text="8-928-130-64-58"/>
            </TextBlock>
        </StackPanel>

        <!-- Таблица -->
        <Border Grid.Row="6" BorderBrush="{DynamicResource InvoiceBorderBrush}" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="36"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Background="{DynamicResource InvoiceHeaderBackgroundBrush}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="150"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" BorderBrush="{DynamicResource InvoiceBorderBrush}" BorderThickness="0,0,1,1" Padding="6">
                        <TextBlock Text="№" FontWeight="Bold" TextAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Border Grid.Column="1" BorderBrush="{DynamicResource InvoiceBorderBrush}" BorderThickness="0,0,1,1" Padding="6">
                        <TextBlock Text="Наименование товара, работ, услуг" FontWeight="Bold" TextWrapping="Wrap" TextAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Border Grid.Column="2" BorderBrush="{DynamicResource InvoiceBorderBrush}" BorderThickness="0,0,1,1" Padding="6">
                        <TextBlock Text="Ед. изм." FontWeight="Bold" TextAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Border Grid.Column="3" BorderBrush="{DynamicResource InvoiceBorderBrush}" BorderThickness="0,0,1,1" Padding="6">
                        <TextBlock Text="Кол-во" FontWeight="Bold" TextAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Border Grid.Column="4" BorderBrush="{DynamicResource InvoiceBorderBrush}" BorderThickness="0,0,1,1" Padding="6">
                        <TextBlock Text="Цена без НДС, руб." FontWeight="Bold" TextWrapping="Wrap" TextAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Border Grid.Column="5" BorderBrush="{DynamicResource InvoiceBorderBrush}" BorderThickness="0,0,0,1" Padding="6">
                        <TextBlock Text="Сумма без НДС, руб." FontWeight="Bold" TextWrapping="Wrap" TextAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>

                <ListView Grid.Row="1"
                          ItemsSource="{Binding OrderDetails, Mode=OneWay}"
                          BorderThickness="0"
                          Background="{DynamicResource InvoiceBackgroundBrush}"
                          Foreground="{DynamicResource InvoiceForegroundBrush}"
                          IsHitTestVisible="False">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                        </Style>
                    </ListView.ItemContainerStyle>

                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="150"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" BorderBrush="{DynamicResource InvoiceBorderBrush}" BorderThickness="0,0,1,1" Padding="6">
                                    <TextBlock Text="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=(ItemsControl.AlternationIndex), ConverterCulture=ru-RU}"
                                               TextAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>

                                <Border Grid.Column="1" BorderBrush="{DynamicResource InvoiceBorderBrush}" BorderThickness="0,0,1,1" Padding="6">
                                    <TextBlock Text="{Binding Product.ProductName, Mode=OneWay}" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                </Border>

                                <Border Grid.Column="2" BorderBrush="{DynamicResource InvoiceBorderBrush}" BorderThickness="0,0,1,1" Padding="6">
                                    <TextBlock Text="шт" TextAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <Border Grid.Column="3" BorderBrush="{DynamicResource InvoiceBorderBrush}" BorderThickness="0,0,1,1" Padding="6">
                                    <TextBlock Text="{Binding OrderDetailQuantity, Mode=OneWay}" TextAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <Border Grid.Column="4" BorderBrush="{DynamicResource InvoiceBorderBrush}" BorderThickness="0,0,1,1" Padding="6">
                                    <TextBlock Text="{Binding Product.ProductPrice, Mode=OneWay}" TextAlignment="Right" VerticalAlignment="Center"/>
                                </Border>

                                <Border Grid.Column="5" BorderBrush="{DynamicResource InvoiceBorderBrush}" BorderThickness="0,0,0,1" Padding="6">
                                    <TextBlock Text="{Binding OrderDetailAmount, Mode=OneWay}" TextAlignment="Right" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

        <!-- Итого -->
        <StackPanel Grid.Row="8" HorizontalAlignment="Right" Width="320">
            <Border BorderBrush="{DynamicResource InvoiceBorderBrush}" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="140"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" BorderBrush="{DynamicResource InvoiceBorderBrush}" BorderThickness="0,0,1,0" Padding="8">
                        <TextBlock Text="Итого без НДС" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </Border>

                    <Border Grid.Column="1" Padding="8">
                        <TextBlock Text="{Binding Order.OrderTotal, Mode=OneWay}" FontWeight="SemiBold" TextAlignment="Right" VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>

            <TextBlock Margin="0,14,0,0"
                       FontSize="16"
                       FontWeight="Bold"
                       TextAlignment="Right">
                <Run Text="Всего к оплате "/>
                <Run Text="{Binding Order.OrderTotal, Mode=OneWay}"/>
                <Run Text=" руб."/>
            </TextBlock>
        </StackPanel>

        <!-- Нижний блок -->
        <StackPanel Grid.Row="10">
            <TextBlock FontSize="14" Margin="0,0,0,14">
                <Run Text="Дополнительная информация: "/>
            </TextBlock>

            <TextBlock FontSize="14" Margin="0,0,0,14">
                <Run Text="Оплатить в течение 3 дней"/>
            </TextBlock>

            <Grid Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="260"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="ИП Бахолдина О. Н."
                           FontSize="14"
                           VerticalAlignment="Center"/>

                <Border Grid.Column="1"
                        Margin="10,0,10,0"
                        BorderBrush="{DynamicResource InvoiceBorderBrush}"
                        BorderThickness="0,0,0,1"
                        Height="24"
                        VerticalAlignment="Bottom"/>

                <TextBlock Grid.Column="2"
                           Text="/Бахолдина О. Н./"
                           FontSize="14"
                           VerticalAlignment="Center"/>
            </Grid>

            <Grid Margin="0,6,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="260"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="1"
                           Text="(подпись)"
                           FontSize="12"
                           HorizontalAlignment="Center"/>

                <TextBlock Grid.Column="2"
                           Text="(расшифровка подписи)"
                           FontSize="12"
                           HorizontalAlignment="Left"/>
            </Grid>

            <TextBlock Margin="0,18,0,0"
                       Text="М.П."
                       FontSize="14"
                       FontWeight="Bold"/>
        </StackPanel>

        <Image Source="pack://application:,,,/Assets/IMSLogo.png" Height="200" VerticalAlignment="Top" Margin="10,150,650,0" Grid.Row="12"/>
    </Grid>
</UserControl>