<UserControl x:Class="StockKeeperMail.Desktop.Views.StorageDetailView"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:views="clr-namespace:StockKeeperMail.Desktop.Views"
             xmlns:local="clr-namespace:StockKeeperMail.Desktop.Views"
             xmlns:controls="clr-namespace:StockKeeperMail.Desktop.Controls"
             mc:Ignorable="d">

    <materialDesign:DialogHost 
        CloseOnClickAway="true" 
        IsOpen="{ Binding IsDialogOpen, Mode=OneWay}" 
        DialogBackground="Transparent">

        <materialDesign:DialogHost.DialogContent>
            <materialDesign:Card UniformCornerRadius="10">
                <ContentControl Content="{ Binding DialogViewModel }"/>
            </materialDesign:Card>
        </materialDesign:DialogHost.DialogContent>

        <Grid Margin="30 30 30 30">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock 
                    Grid.Column="0" 
                    Text="{Binding Location.LocationName}"
                    Style="{StaticResource MaterialDesignHeadline4TextBlock}"
                    FontWeight="Bold"/>

                <Button
                    Grid.Column="1"
                    Style="{StaticResource MaterialDesignPaperButton}"
                    Command="{
                        Binding DataContext.AddProductCommand, 
                        RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=views:StorageDetailView}}"
                    CommandParameter="{Binding}">
                    <materialDesign:PackIcon Kind="Add"/>
                </Button>
            </Grid>

            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="auto"/>
                </Grid.RowDefinitions>

                <DataGrid
                    Grid.Row="0"
                    ItemsSource="{Binding ProductLocations}"
                    Style="{StaticResource MaterialDesignDataGrid}"
                    BorderBrush="{DynamicResource BrandPrimaryDarkBrush}"
                    BorderThickness="2"
                    IsReadOnly="True"
                    AutoGenerateColumns="False"
                    RowHeight="54">

                    <DataGrid.Columns>
                        <DataGridTextColumn
                            Header="Товар"
                            HeaderStyle="{StaticResource MaterialDesignDataGridColumnHeader}"
                            CellStyle="{StaticResource MaterialDesignDataGridCell}"
                            Binding="{Binding Product.ProductName}"
                            Width="*"/>

                        <DataGridTextColumn
                            Header="Количество"
                            HeaderStyle="{StaticResource MaterialDesignDataGridColumnHeader}"
                            CellStyle="{StaticResource MaterialDesignDataGridCell}"
                            Binding="{Binding ProductQuantity}"
                            Width="140"/>

                        <DataGridTemplateColumn 
                            Header="Действия"
                            HeaderStyle="{StaticResource MaterialDesignDataGridColumnHeader}"
                            Width="620">

                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Left">

                                        <StackPanel.Resources>
                                            <Style TargetType="Button"
                                                   BasedOn="{StaticResource MaterialDesignPaperButton}">
                                                <Setter Property="Height" Value="34"/>
                                                <Setter Property="Padding" Value="14,0"/>
                                                <Setter Property="Margin" Value="0,0,8,0"/>
                                                <Setter Property="BorderBrush" Value="Orange"/>
                                                <Setter Property="BorderThickness" Value="1.2"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                                            </Style>
                                        </StackPanel.Resources>

                                        <Button
                                            Content="Получить"
                                            MinWidth="100"
                                            Command="{
                                                Binding DataContext.GetProductCommand, 
                                                RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=views:StorageDetailView}}"
                                            CommandParameter="{Binding}"/>

                                        <Button
                                            Content="Переместить"
                                            MinWidth="126"
                                            Command="{
                                                Binding DataContext.MoveProductCommand, 
                                                RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=views:StorageDetailView}}"
                                            CommandParameter="{Binding}"/>

                                        <Button
                                            Content="Списать"
                                            MinWidth="100"
                                            Command="{
                                                Binding DataContext.DisposeProductCommand, 
                                                RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=views:StorageDetailView}}"
                                            CommandParameter="{Binding}"/>

                                        <Button
                                            Content="Объявить бракованным"
                                            MinWidth="190"
                                            Margin="0"
                                            Command="{
                                                Binding DataContext.DeclareDefectiveProductCommand, 
                                                RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=views:StorageDetailView}}"
                                            CommandParameter="{Binding}"/>

                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <controls:FilterControl Filter="{Binding StorageDetailListViewHelper.Filter}"/>
                    </Grid>

                    <Grid Grid.Column="1">
                        <controls:PaginationControl
                            CurrentPage="{Binding StorageDetailListViewHelper.CurrentPage}"
                            NumberOfPages="{Binding StorageDetailListViewHelper.NumberOfPages}"
                            RecordsPerPage="{Binding StorageDetailListViewHelper.RecordsPerPage}"
                            SelectedRecordsPerPage="{Binding StorageDetailListViewHelper.SelectedRecordsPerPage}"
                            FirstPageCommand="{Binding StorageDetailListViewHelper.FirstPageCommand}"
                            PreviousPageCommand="{Binding StorageDetailListViewHelper.PreviousPageCommand}"
                            NextPageCommand="{Binding StorageDetailListViewHelper.NextPageCommand}"
                            LastPageCommand="{Binding StorageDetailListViewHelper.LastPageCommand}"/>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </materialDesign:DialogHost>
</UserControl>