<UserControl x:Class="StockKeeperMail.Desktop.Views.CreateOrderView"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:views="clr-namespace:StockKeeperMail.Desktop.Views"
             mc:Ignorable="d" 
             d:DesignHeight="1080" d:DesignWidth="1920">

    <materialDesign:DialogHost IsOpen="{Binding IsDialogOpen, Mode=OneWay}">
        <materialDesign:DialogHost.DialogContent>
            <materialDesign:Card UniformCornerRadius="10">
                <ContentControl Content="{Binding DialogViewModel}"/>
            </materialDesign:Card>
        </materialDesign:DialogHost.DialogContent>

        <Grid Margin="50">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Style="{StaticResource MaterialDesignHeadline4TextBlock}"
                       FontWeight="Bold"
                       Text="Данные заказа"/>

            <Grid Grid.Row="1" Margin="0,30,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="22"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Клиент" Style="{StaticResource MaterialDesignTextBlock}" FontWeight="DemiBold"/>
                    <ComboBox Style="{StaticResource MaterialDesignComboBox}"
                              Padding="10"
                              SelectedValue="{Binding CustomerID, UpdateSourceTrigger=PropertyChanged}"
                              SelectedValuePath="CustomerID"
                              ItemsSource="{Binding Customers}">
                        <ComboBox.ItemTemplate>
                            <ItemContainerTemplate>
                                <TextBlock Text="{Binding CustomerFullname}"/>
                            </ItemContainerTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Внешний номер заказа" Style="{StaticResource MaterialDesignTextBlock}" FontWeight="DemiBold"/>
                    <TextBox Style="{StaticResource MaterialDesignTextBox}"
                             Padding="10"
                             Text="{Binding ExternalOrderNumber, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="2" Margin="0,22,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="22"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <CheckBox Grid.Column="0"
                          Content="Онлайн заказ"
                          IsChecked="{Binding IsOnlineOrder}"
                          VerticalAlignment="Center"
                          FontWeight="DemiBold"/>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Адрес доставки покупателя" Style="{StaticResource MaterialDesignTextBlock}" FontWeight="DemiBold"/>
                    <TextBox Style="{StaticResource MaterialDesignTextBox}"
                             Padding="10"
                             Text="{Binding DeliveryAddress, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="3" Margin="0,30,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Margin="0,0,30,0"
                               Text="Добавить товар"
                               VerticalAlignment="Center"
                               Style="{StaticResource MaterialDesignTextBlock}"
                               FontWeight="DemiBold"/>

                    <Button Command="{Binding CreateOrderDetailCommand}"
                            Style="{StaticResource MaterialDesignPaperButton}"
                            Width="60">
                        <materialDesign:PackIcon Kind="Add"/>
                    </Button>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="4" Margin="0,30,0,0">
                <DataGrid ItemsSource="{Binding OrderDetails}"
                          Style="{StaticResource MaterialDesignDataGrid}"
                          BorderBrush="{DynamicResource BrandPrimaryDarkBrush}"
                          BorderThickness="2"
                          IsReadOnly="True"
                          AutoGenerateColumns="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Товар"
                                            HeaderStyle="{StaticResource MaterialDesignDataGridColumnHeader}"
                                            CellStyle="{StaticResource MaterialDesignDataGridCell}"
                                            Binding="{Binding Product.ProductName}"
                                            Width="*"
                                            MinWidth="180"/>

                        <DataGridTextColumn Header="Количество"
                                            HeaderStyle="{StaticResource MaterialDesignDataGridColumnHeader}"
                                            CellStyle="{StaticResource MaterialDesignDataGridCell}"
                                            Binding="{Binding OrderDetailQuantity}"
                                            Width="140"/>

                        <DataGridTextColumn Header="Сумма"
                                            HeaderStyle="{StaticResource MaterialDesignDataGridColumnHeader}"
                                            CellStyle="{StaticResource MaterialDesignDataGridCell}"
                                            Binding="{Binding OrderDetailAmount}"
                                            Width="160"/>

                        <DataGridTemplateColumn Header="Действия" HeaderStyle="{StaticResource MaterialDesignDataGridColumnHeader}" Width="150">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button BorderBrush="Orange"
                                                Margin="0,0,5,0"
                                                Style="{StaticResource MaterialDesignPaperButton}"
                                                Command="{Binding DataContext.EditOrderDetailCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=views:CreateOrderView}}"
                                                CommandParameter="{Binding}">
                                            <materialDesign:PackIcon Kind="Edit"/>
                                        </Button>

                                        <Button BorderBrush="Red"
                                                Style="{StaticResource MaterialDesignPaperButton}"
                                                Command="{Binding DataContext.RemoveOrderDetailCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=views:CreateOrderView}}"
                                                CommandParameter="{Binding}">
                                            <materialDesign:PackIcon Kind="Remove"/>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <Grid Grid.Row="5" Margin="0,30,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="Итого" Margin="0,0,30,0" Style="{StaticResource MaterialDesignTextBlock}" FontWeight="DemiBold"/>
                    <TextBlock MinWidth="300" Text="{Binding OrderTotal, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MaterialDesignTextBlock}"/>
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="6" Orientation="Horizontal" Margin="0,30,0,0" HorizontalAlignment="Right">
                <Button Content="Сохранить" Command="{Binding SubmitCommand}" CommandParameter="{Binding}" Style="{StaticResource MaterialDesignPaperButton}"/>
                <Button Margin="10,0,0,0" Content="Отмена" Command="{Binding CancelCommand}" Style="{StaticResource MaterialDesignPaperLightButton}"/>
            </StackPanel>
        </Grid>
    </materialDesign:DialogHost>
</UserControl>
