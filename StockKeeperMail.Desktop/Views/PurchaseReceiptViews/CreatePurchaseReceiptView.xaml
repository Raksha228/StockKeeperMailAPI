<UserControl x:Class="StockKeeperMail.Desktop.Views.CreatePurchaseReceiptView"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="720" d:DesignWidth="820">

    <Grid Width="780" Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Закуп товара"
                       Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                       FontWeight="Bold"/>
            <TextBlock Text="Поступление фиксируется текущей датой и увеличивает общий остаток выбранного товара."
                       Margin="0,6,0,0"
                       Foreground="{DynamicResource BrandMutedTextBrush}"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="18"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,16">
                <TextBlock Text="Поставщик" FontWeight="DemiBold"/>
                <ComboBox ItemsSource="{Binding Suppliers}"
                          SelectedValue="{Binding SupplierID, UpdateSourceTrigger=PropertyChanged}"
                          SelectedValuePath="SupplierID"
                          Style="{StaticResource MaterialDesignComboBox}"
                          Padding="10">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding SupplierName}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>

            <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,16">
                <TextBlock Text="Товар" FontWeight="DemiBold"/>
                <ComboBox ItemsSource="{Binding Products}"
                          SelectedValue="{Binding ProductID, UpdateSourceTrigger=PropertyChanged}"
                          SelectedValuePath="ProductID"
                          Style="{StaticResource MaterialDesignComboBox}"
                          Padding="10">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding ProductName}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>

            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,16">
                <TextBlock Text="Склад поступления" FontWeight="DemiBold"/>
                <ComboBox ItemsSource="{Binding Warehouses}"
                          SelectedValue="{Binding WarehouseID, UpdateSourceTrigger=PropertyChanged}"
                          SelectedValuePath="WarehouseID"
                          Style="{StaticResource MaterialDesignComboBox}"
                          Padding="10">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding WarehouseName}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>

            <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,16">
                <TextBlock Text="Номер документа поставщика" FontWeight="DemiBold"/>
                <TextBox Text="{Binding DocumentNumber, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource MaterialDesignTextBox}"
                         Padding="10"/>
            </StackPanel>

            <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,0,16">
                <TextBlock Text="Количество" FontWeight="DemiBold"/>
                <TextBox Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource MaterialDesignTextBox}"
                         Padding="10"/>
            </StackPanel>

            <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,0,0,16">
                <TextBlock Text="Закупочная цена за единицу" FontWeight="DemiBold"/>
                <TextBox Text="{Binding UnitPrice, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource MaterialDesignTextBox}"
                         Padding="10"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="2" Margin="0,4,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="18"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Дата регистрации" FontWeight="DemiBold"/>
                <TextBox Text="{Binding PurchasedAt, Mode=OneWay}"
                         IsReadOnly="True"
                         Style="{StaticResource MaterialDesignTextBox}"
                         Padding="10"/>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock Text="Итоговая сумма" FontWeight="DemiBold"/>
                <TextBox Text="{Binding TotalAmountPreview, Mode=OneWay}"
                         IsReadOnly="True"
                         Style="{StaticResource MaterialDesignTextBox}"
                         Padding="10"/>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="3" Margin="0,18,0,0">
            <TextBlock Text="Комментарий" FontWeight="DemiBold"/>
            <TextBox Text="{Binding Comment, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource MaterialDesignTextBox}"
                     Padding="10"
                     MinHeight="86"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"/>
        </StackPanel>

        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,28,0,0">
            <Button Content="Сохранить приход"
                    Command="{Binding SubmitCommand}"
                    Style="{StaticResource MaterialDesignPaperButton}"/>
            <Button Content="Отмена"
                    Margin="10,0,0,0"
                    Command="{Binding CancelCommand}"
                    Style="{StaticResource MaterialDesignPaperLightButton}"/>
        </StackPanel>
    </Grid>
</UserControl>
