<UserControl x:Class="StockKeeperMail.Desktop.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:StockKeeperMail.Desktop.Views"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:StockKeeperMail.Desktop.Converters">

    <materialDesign:Card
        Height="540"
        Width="340"
        UniformCornerRadius="18" 
        Background="{DynamicResource MaterialDesignPaper}" 
        materialDesign:ElevationAssist.Elevation="Dp12">

        <materialDesign:DialogHost CloseOnClickAway="True" x:Name="DialogHost">
            <StackPanel>
                <materialDesign:PopupBox HorizontalAlignment="Right" Margin="0 20 20 0" PlacementMode="BottomAndAlignRightEdges" StaysOpen="False" Height="25">
                    <StackPanel>
                        <StackPanel Margin="16 10 0 6" Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock VerticalAlignment="Center" Text="Тёмная тема"/>
                            <ToggleButton Cursor="Hand" ToolTip="Включить тёмную тему" Margin="12 0 8 0" x:Name="themeToggle" IsChecked="{Binding IsDarkTheme}" Command="{Binding ToggleThemeCommand}"/>
                        </StackPanel>

                        <Button ToolTip="Проблемы со входом?" Margin="0 8 0 0" Content="Помощь" Command="{Binding HelpCommand}"/>
                        <Button x:Name="btn_exit" ToolTip="Закрыть приложение" Content="Выход" Command="{Binding ExitAppCommand}"/>
                    </StackPanel>
                </materialDesign:PopupBox>

                <Image Source="pack://application:,,,/Assets/IMSLogo.png" Height="88" Margin="0,8,0,0"/>

                <TextBlock Margin="0 14 0 0" HorizontalAlignment="Center" FontSize="28" FontWeight="Bold">
                    <Run Text="ВОЛГО" Foreground="{DynamicResource BrandPrimaryBrush}"/>
                    <Run Text="-МЕД" Foreground="{DynamicResource BrandAccentBrush}"/>
                </TextBlock>

                <TextBlock Margin="0 8 0 0" HorizontalAlignment="Center" FontSize="14" Opacity="0.78" Text="Корпоративная система"/>
                <TextBlock Margin="0 2 0 0" HorizontalAlignment="Center" FontSize="14" Opacity="0.78" Text="Склад и внутренняя почта"/>

                <StackPanel Margin="50 8 50 0">
                    <TextBox 
                        Margin="0 30 0 0" 
                        x:Name="txtUsername" 
                        materialDesign:HintAssist.Hint="Введите имя пользователя" 
                        BorderThickness="2"
                        Padding="10"
                        Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                        BorderBrush="{DynamicResource MaterialDesignDivider}" 
                        Style="{StaticResource MaterialDesignOutlinedTextBox}"/>

                    <PasswordBox 
                        Margin="0 20 0 0"
                        x:Name="txtPassword" 
                        Padding="10"
                        materialDesign:HintAssist.Hint="Введите пароль" 
                        BorderThickness="2"      
                        BorderBrush="{DynamicResource MaterialDesignDivider}" 
                        Style="{StaticResource MaterialDesignOutlinedPasswordBox}"/>

                    <Button 
                        Margin="0 24 0 0" 
                        x:Name="loginBtn" 
                        Style="{StaticResource MaterialDesignFlatMidBgButton}"
                        materialDesign:ElevationAssist.Elevation="Dp0" 
                        materialDesign:ButtonAssist.CornerRadius="10" 
                        Content="Войти" 
                        Command="{Binding LoginUserCommand}"
                        CommandParameter="{Binding ElementName=txtPassword}"/>
                </StackPanel>
            </StackPanel>
        </materialDesign:DialogHost>
    </materialDesign:Card>
</UserControl>
