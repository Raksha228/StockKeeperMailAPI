<UserControl x:Class="StockKeeperMail.Desktop.Views.CredentialListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:StockKeeperMail.Desktop.Controls"
             mc:Ignorable="d"
             d:DesignHeight="1080"
             d:DesignWidth="1920">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="Учетные данные"
                           Style="{StaticResource MaterialDesignHeadline4TextBlock}"
                           FontWeight="Bold"/>
                <TextBlock Margin="0,8,0,0"
                           Text="Раздел для просмотра данных пользователей, включая логины и пароли в открытом виде."
                           Opacity="0.75"/>
            </StackPanel>

            <Button Grid.Column="1"
                    Width="46"
                    Height="46"
                    Command="{Binding LoadCredentialsCommand}">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignPaperButton}"/>
                </Button.Style>
                <TextBlock Text="↻" FontSize="18" FontWeight="Bold"/>
            </Button>
        </Grid>

        <Grid Grid.Row="1" Margin="0,20,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <DataGrid Grid.Row="0"
                      ItemsSource="{Binding Credentials}"
                      Style="{StaticResource MaterialDesignDataGrid}"
                      BorderBrush="{DynamicResource BrandPrimaryDarkBrush}"
                      BorderThickness="2"
                      IsReadOnly="True"
                      AutoGenerateColumns="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ФИО"
                                        HeaderStyle="{StaticResource MaterialDesignDataGridColumnHeader}"
                                        CellStyle="{StaticResource MaterialDesignDataGridCell}"
                                        Binding="{Binding StaffFullname}"
                                        Width="220"/>

                    <DataGridTextColumn Header="Логин"
                                        HeaderStyle="{StaticResource MaterialDesignDataGridColumnHeader}"
                                        CellStyle="{StaticResource MaterialDesignDataGridCell}"
                                        Binding="{Binding StaffUsername}"
                                        Width="160"/>

                    <DataGridTextColumn Header="Пароль"
                                        HeaderStyle="{StaticResource MaterialDesignDataGridColumnHeader}"
                                        CellStyle="{StaticResource MaterialDesignDataGridCell}"
                                        Binding="{Binding StaffPassword}"
                                        Width="160"/>

                    <DataGridTextColumn Header="Роль"
                                        HeaderStyle="{StaticResource MaterialDesignDataGridColumnHeader}"
                                        CellStyle="{StaticResource MaterialDesignDataGridCell}"
                                        Binding="{Binding Role.RoleName}"
                                        Width="160"/>

                    <DataGridTextColumn Header="Email"
                                        HeaderStyle="{StaticResource MaterialDesignDataGridColumnHeader}"
                                        CellStyle="{StaticResource MaterialDesignDataGridCell}"
                                        Binding="{Binding StaffEmail}"
                                        Width="200"/>

                    <DataGridTextColumn Header="Телефон"
                                        HeaderStyle="{StaticResource MaterialDesignDataGridColumnHeader}"
                                        CellStyle="{StaticResource MaterialDesignDataGridCell}"
                                        Binding="{Binding StaffPhone}"
                                        Width="160"/>

                    <DataGridTextColumn Header="Адрес"
                                        HeaderStyle="{StaticResource MaterialDesignDataGridColumnHeader}"
                                        CellStyle="{StaticResource MaterialDesignDataGridCell}"
                                        Binding="{Binding StaffAddress}"
                                        Width="260"/>

                    <DataGridTextColumn Header="ID"
                                        HeaderStyle="{StaticResource MaterialDesignDataGridColumnHeader}"
                                        CellStyle="{StaticResource MaterialDesignDataGridCell}"
                                        Binding="{Binding StaffID}"
                                        Width="260"/>
                </DataGrid.Columns>
            </DataGrid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <controls:FilterControl Filter="{Binding CredentialListViewHelper.Filter}"/>
                </Grid>

                <Grid Grid.Column="1">
                    <controls:PaginationControl CurrentPage="{Binding CredentialListViewHelper.CurrentPage}"
                                                NumberOfPages="{Binding CredentialListViewHelper.NumberOfPages}"
                                                RecordsPerPage="{Binding CredentialListViewHelper.RecordsPerPage}"
                                                SelectedRecordsPerPage="{Binding CredentialListViewHelper.SelectedRecordsPerPage}"
                                                FirstPageCommand="{Binding CredentialListViewHelper.FirstPageCommand}"
                                                PreviousPageCommand="{Binding CredentialListViewHelper.PreviousPageCommand}"
                                                NextPageCommand="{Binding CredentialListViewHelper.NextPageCommand}"
                                                LastPageCommand="{Binding CredentialListViewHelper.LastPageCommand}"/>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
