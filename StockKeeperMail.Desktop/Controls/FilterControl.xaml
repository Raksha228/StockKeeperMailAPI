<UserControl x:Class="StockKeeperMail.Desktop.Controls.FilterControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:StockKeeperMail.Desktop.Controls"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Name="CustomFilterControl"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <Border CornerRadius="18" Background="{DynamicResource BrandSurfaceBrush}" BorderBrush="{DynamicResource BrandBorderBrush}" BorderThickness="1" Padding="12,4">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <materialDesign:PackIcon Kind="Magnify" Width="22" Height="22" Foreground="{DynamicResource BrandPrimaryBrush}" VerticalAlignment="Center"/>
            <TextBox Text="{Binding Filter, ElementName=CustomFilterControl, UpdateSourceTrigger=PropertyChanged}"
                     Width="260"
                     Margin="10,0,0,0"
                     VerticalAlignment="Center"
                     BorderThickness="0"
                     Background="Transparent"
                     materialDesign:HintAssist.Hint="Поиск и фильтр"/>
        </StackPanel>
    </Border>
</UserControl>
