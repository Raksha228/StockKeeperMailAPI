<Window x:Class="StockKeeperMail.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:StockKeeperMail.Desktop"
        xmlns:controls="clr-namespace:StockKeeperMail.Desktop.Controls"
        mc:Ignorable="d"
        d:Width="1920"
        d:Height="1080"
        Title="Волго-Мед — корпоративная система"
        WindowState="Maximized"
        Icon="pack://application:,,,/Assets/logo.png"
        WindowStyle="None"
        Background="{DynamicResource MaterialDesignBackground}"
        Foreground="{DynamicResource MaterialDesignBody}"
        FontFamily="Segoe UI">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Width="220">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsLoggedIn}" Value="False">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>

                <controls:NavigationBar/>
            </Grid>

            <Grid Grid.Column="1" Background="{DynamicResource MaterialDesignBackground}">
                <ContentControl Content="{Binding CurrentViewModel}" Background="{DynamicResource MaterialDesignBackground}"/>
            </Grid>
        </Grid>

        <Label Grid.Row="1" HorizontalAlignment="Center" FontWeight="SemiBold" FontSize="10" Padding="0,8,0,12">
            <StackPanel>
                <TextBlock Text="ИП Бахолдин • Волго-Мед" HorizontalAlignment="Center"/>
                <TextBlock Text="Инвентаризация складских запасов и внутренняя почта" HorizontalAlignment="Center"/>
            </StackPanel>
        </Label>
    </Grid>
</Window>
