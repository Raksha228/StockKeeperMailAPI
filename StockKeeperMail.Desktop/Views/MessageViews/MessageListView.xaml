<UserControl x:Class="StockKeeperMail.Desktop.Views.MessageListView"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" 
             d:DesignHeight="1080" d:DesignWidth="1920"
             d:Background="White">

    <UserControl.Resources>
        <Style x:Key="MessagesTabItemStyle" TargetType="{x:Type TabItem}">
            <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabItem}">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="0,0,0,2"
                                Padding="14,8"
                                Margin="0,0,8,0">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource PrimaryHueMidBrush}" />
                                <Setter TargetName="Bd" Property="Background" Value="#140B3BDE" />
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryHueMidBrush}" />
                            </Trigger>

                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#0D0B3BDE" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    
    <materialDesign:DialogHost 
        CloseOnClickAway="false"
        IsOpen="{Binding IsDialogOpen, Mode=OneWay}"
        DialogBackground="Transparent">

        <materialDesign:DialogHost.DialogContent>
            <materialDesign:Card UniformCornerRadius="10">
                <ContentControl Content="{Binding DialogViewModel}" />
            </materialDesign:Card>
        </materialDesign:DialogHost.DialogContent>

        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Column="0"
                    Text="Сообщения"
                    Style="{StaticResource MaterialDesignHeadline4TextBlock}"
                    FontWeight="Bold" />

                <Button
                    Grid.Column="1"
                    Margin="0,0,10,0"
                    Command="{Binding RefreshMessagesCommand}"
                    Style="{StaticResource MaterialDesignPaperButton}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Refresh" Margin="0,0,5,0" />
                        <TextBlock Text="Обновить" />
                    </StackPanel>
                </Button>

                <Button
                    Grid.Column="2"
                    Command="{Binding OpenComposeDialogCommand}"
                    Style="{StaticResource MaterialDesignPaperButton}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Pencil" Margin="0,0,5,0" />
                        <TextBlock Text="Написать" />
                    </StackPanel>
                </Button>
            </Grid>

            <Grid Grid.Row="1" Margin="0,20,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="320" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TabControl Grid.Column="0"
                            Background="Transparent"
                            BorderThickness="0"
                            SelectedIndex="{Binding SelectedFolderIndex, Mode=TwoWay}"> 
                    <TabControl.ItemContainerStyle>
                        <Style TargetType="{x:Type TabItem}" BasedOn="{StaticResource MessagesTabItemStyle}" />
                    </TabControl.ItemContainerStyle>

                    <TabItem Header="Входящие" />
                    <TabItem Header="Отправленные" />
                </TabControl>

                <Grid Grid.Column="1" Margin="20,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="320" />
                    </Grid.ColumnDefinitions>

                    <TextBlock
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        Margin="0,0,10,0"
                        Text="{Binding MailboxFilterLabel}"
                        FontWeight="DemiBold" />

                    <ComboBox
                        Grid.Column="1"
                        ItemsSource="{Binding MailboxUsers}"
                        DisplayMemberPath="DisplayName"
                        SelectedValuePath="StaffID"
                        SelectedValue="{Binding SelectedMailboxStaffID, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        Style="{StaticResource MaterialDesignComboBox}" />
                </Grid>
            </Grid>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="2*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" BorderBrush="#22000000" BorderThickness="1" CornerRadius="6">
                    <DataGrid
                        ItemsSource="{Binding Messages}"
                        SelectedItem="{Binding SelectedMessage, Mode=TwoWay}"
                        Style="{StaticResource MaterialDesignDataGrid}"
                        AutoGenerateColumns="False"
                        IsReadOnly="True"
                        HeadersVisibility="Column"
                        BorderThickness="0"
                        Background="{DynamicResource MaterialDesignPaper}"
                        Foreground="{DynamicResource MaterialDesignBody}"
                        RowBackground="{DynamicResource MaterialDesignPaper}"
                        AlternatingRowBackground="{DynamicResource MaterialDesignPaper}">

                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="FontWeight" Value="{Binding RowFontWeight}" />
                                <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}" />
                                <Setter Property="Background" Value="{DynamicResource MaterialDesignPaper}" />
                            </Style>
                        </DataGrid.RowStyle>

                        <DataGrid.Columns>
                            <DataGridTextColumn
                                Header="Автор"
                                HeaderStyle="{StaticResource MaterialDesignDataGridColumnHeader}"
                                CellStyle="{StaticResource MaterialDesignDataGridCell}"
                                Binding="{Binding CounterpartyFullName}"
                                Width="2*" />

                            <DataGridTextColumn
                                Header="Должность"
                                HeaderStyle="{StaticResource MaterialDesignDataGridColumnHeader}"
                                CellStyle="{StaticResource MaterialDesignDataGridCell}"
                                Binding="{Binding CounterpartyRoleName}"
                                Width="*" />

                            <DataGridTextColumn
                                Header="Тема"
                                HeaderStyle="{StaticResource MaterialDesignDataGridColumnHeader}"
                                CellStyle="{StaticResource MaterialDesignDataGridCell}"
                                Binding="{Binding Subject}"
                                Width="3*" />

                            <DataGridTextColumn
                                Header="Дата"
                                HeaderStyle="{StaticResource MaterialDesignDataGridColumnHeader}"
                                CellStyle="{StaticResource MaterialDesignDataGridCell}"
                                Binding="{Binding SentAtDisplay}"
                                Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <Border Grid.Column="2" Padding="20" BorderBrush="#22000000" BorderThickness="1" CornerRadius="6">
                    <Grid>
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedMessage}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock
                            Grid.Row="0"
                            Text="{Binding SelectedMessage.Subject}"
                            FontSize="22"
                            FontWeight="Bold"
                            TextWrapping="Wrap" />

                        <Grid Grid.Row="1" Margin="0,20,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Margin="0,0,0,8">
                                <Run Text="От: " FontWeight="Bold" />
                                <Run Text="{Binding SelectedMessage.SenderFullName, Mode=OneWay}" />
                                <Run Text=" — " />
                                <Run Text="{Binding SelectedMessage.SenderRoleName, Mode=OneWay}" />
                            </TextBlock>

                            <TextBlock Grid.Row="1" Margin="0,0,0,8">
                                <Run Text="Кому: " FontWeight="Bold" />
                                <Run Text="{Binding SelectedMessage.RecipientFullName, Mode=OneWay}" />
                                <Run Text=" — " />
                                <Run Text="{Binding SelectedMessage.RecipientRoleName, Mode=OneWay}" />
                            </TextBlock>

                            <TextBlock Grid.Row="2" Margin="0,0,0,8">
                                <Run Text="Дата: " FontWeight="Bold" />
                                <Run Text="{Binding SelectedMessage.SentAtDisplay, Mode=OneWay}" />
                            </TextBlock>

                            <TextBlock Grid.Row="3">
                                <Run Text="Логин автора: " FontWeight="Bold" />
                                <Run Text="{Binding SelectedMessage.SenderUsername, Mode=OneWay}" />
                            </TextBlock>
                        </Grid>

                        <TextBlock
                            Grid.Row="2"
                            Margin="0,20,0,10"
                            Text="Текст сообщения"
                            FontWeight="Bold"
                            FontSize="16" />

                        <Border Grid.Row="3" Padding="15" Background="{DynamicResource MaterialDesignPaper}" CornerRadius="6">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <TextBlock
                                    Text="{Binding SelectedMessage.Body}"
                                    TextWrapping="Wrap"
                                    FontSize="14" />
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Column="2" Padding="30" BorderBrush="#22000000" BorderThickness="1" CornerRadius="6">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedMessage}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>

                    <StackPanel VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="EmailOutline" Width="48" Height="48" HorizontalAlignment="Center" />
                        <TextBlock
                            Margin="0,20,0,0"
                            Text="Выберите письмо из списка, чтобы просмотреть его содержимое."
                            TextWrapping="Wrap"
                            HorizontalAlignment="Center"
                            TextAlignment="Center"
                            FontSize="16" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </materialDesign:DialogHost>
</UserControl>
